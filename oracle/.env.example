# --- Solana / WorldXI programı ---
# Devnet RPC (varsayılan Solana devnet)
RPC_URL=https://api.devnet.solana.com
# WorldXI Anchor program ID
PROGRAM_ID=A5dEqv3cB8tpxT1vQ6WTc88hC5vSvE6unSQvWodMvAfL
# Turnuva adı (init_tournament ile aynı olmalı)
TOURNAMENT_NAME=WC2026
# Oracle keypair dosya yolu (commit_score imzalar, ScoreCommit rent'ini öder)
ORACLE_KEYPAIR=/absolute/path/to/oracle-keypair.json

# --- TxLINE (zorunlu veri sağlayıcısı) ---
# mainnet: https://txline.txodds.com  |  devnet: https://txline-dev.txodds.com
TXLINE_BASE_URL=https://txline.txodds.com
# WC 2026 competition id (bilinmiyorsa boş bırak; pipeline "World Cup" adına göre keşfeder)
TXLINE_COMPETITION_ID=
# Seçilen ligler (activation için); WC free tier'da genelde boş veya WC lig id'si
TXLINE_LEAGUES=
# YÖNTEM A — hazır token (elle aktive ettiysen):
TXLINE_JWT=
TXLINE_API_TOKEN=
# YÖNTEM B — otomatik aktivasyon: guest JWT alınır, aşağıdaki subscribe txSig ile aktive edilir.
# subscribe işlemini TxLINE Solana programına gönderip imzasını buraya koy (txline:subscribe scripti yardımcı olur).
TXLINE_SUBSCRIBE_TXSIG=
# Aktivasyon mesajını imzalayacak cüzdan (subscribe eden cüzdan). Boşsa ORACLE_KEYPAIR kullanılır.
TXLINE_WALLET_KEYPAIR=

# --- API-Football (ikinci gerçek feed: asist + penaltı kurtarma) ---
# api-sports.io v3. Kaynak: doğrudan API-Sports anahtarı VEYA RapidAPI anahtarı.
APIFOOTBALL_BASE_URL=https://v3.football.api-sports.io
APIFOOTBALL_KEY=
# RapidAPI kullanıyorsan: true (header x-rapidapi-key olur)
APIFOOTBALL_VIA_RAPIDAPI=false
# API-Football lig id'si (World Cup = 1) ve sezon
APIFOOTBALL_LEAGUE_ID=1
APIFOOTBALL_SEASON=2026

# --- Leaderboard API sunucusu ---
API_PORT=8787
